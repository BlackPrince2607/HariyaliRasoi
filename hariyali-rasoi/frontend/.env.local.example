# Local dev (same machine)
NEXT_PUBLIC_API_URL=http://localhost:8000
API_INTERNAL_URL=http://127.0.0.1:8000
NEXT_PUBLIC_WHATSAPP_NUMBER=919XXXXXXXXX
NEXT_PUBLIC_APP_URL=http://localhost:3000

# LAN HMR — your PC IP (see ipconfig). Restart dev server after changing.
# ALLOWED_DEV_ORIGINS=192.168.29.195
#
# Phone / LAN testing (http://192.168.x.x:3000):
# - API calls are proxied by Next.js (/api → 127.0.0.1:8000)
# - Only port 3000 must be reachable on your PC — not 8000
#
# Backend (localhost only is fine):
#   uvicorn app.main:app --reload --host 127.0.0.1 --port 8000
#
# Frontend (listens on all interfaces):
#   npm run dev
#
# On phone: http://YOUR_PC_IP:3000
