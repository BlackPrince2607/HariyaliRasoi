# Local Docker Postgres:
# DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/hariyali_rasoi
# Supabase direct (replace password; add ?ssl=require):
# DATABASE_URL=postgresql+asyncpg://postgres:YOUR_PASSWORD@db.PROJECT_REF.supabase.co:5432/postgres?ssl=require
# Supabase Session Pooler (IPv4-friendly; from dashboard → Connect → Session mode):
# Use postgresql+asyncpg:// (not postgresql://). Host may be aws-0- or aws-1- per dashboard.
# DATABASE_URL=postgresql+asyncpg://postgres.PROJECT_REF:YOUR_PASSWORD@aws-1-REGION.pooler.supabase.com:5432/postgres?ssl=require
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/hariyali_rasoi
SECRET_KEY=your-super-secret-jwt-key-minimum-32-characters
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

ADMIN_EMAIL=admin@hariyalirasoi.com
ADMIN_PASSWORD=$2b$12$...bcrypt-hash-here...

SUPABASE_URL=https://PROJECT_REF.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key

ENVIRONMENT=development
# Set to production on live servers (disables /docs)
WHATSAPP_NUMBER=919XXXXXXXXX
APP_URL=http://localhost:8000
# Comma-separated frontend URLs allowed to call the API (add your Vercel/custom domain)
CORS_ORIGINS=http://localhost:3000,https://your-domain.vercel.app
